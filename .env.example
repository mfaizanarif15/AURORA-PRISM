DATABASE_URL=postgresql+asyncpg://aurora:aurora@localhost:55433/aurora_prism
FRONTEND_ORIGIN=http://localhost:6173
STORAGE_ROOT=./storage
ANALYSIS_MODE=true
AI_PROVIDER=azure_openai

# Local app auth. These credentials can bootstrap the first database user.
# Replace password and session secret for any shared environment.
AUTH_ENABLED=true
AUTH_USERNAME=admin
AUTH_PASSWORD=aurora-admin
AUTH_DISPLAY_NAME=AURORA Operator
AUTH_ROLE=Content Operations
AUTH_SESSION_SECRET=change-this-session-secret
AUTH_TOKEN_TTL_MINUTES=480

# Azure OpenAI is the default provider.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2025-03-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
# Existing aliases are also supported: AZURE_API_BASE, AZURE_API_KEY, AZURE_API_VERSION, AZURE_DEPLOYMENT.

# Standard OpenAI is available as the second provider.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional observability and debugging.
LOG_LEVEL=INFO
LOG_TO_FILE=true
# LOG_FILE=./storage/logs/backend.log
LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=pk-lf-aurora-prism-local
LANGFUSE_SECRET_KEY=sk-lf-aurora-prism-local
LANGFUSE_BASE_URL=http://localhost:3005
LANGFUSE_DOCKER_BASE_URL=http://host.docker.internal:3005
LANGFUSE_ENVIRONMENT=local
LANGFUSE_RELEASE=aurora-prism-mvp
LANGFUSE_CAPTURE_LLM_IO=true
LANGFUSE_MAX_LLM_IO_CHARS=250000
LANGFUSE_HOST_PORT=3005
LANGFUSE_INIT_ORG_NAME=AURORA PRISM Local
LANGFUSE_INIT_PROJECT_NAME=AURORA PRISM Local
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-aurora-prism-local
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-aurora-prism-local

DEMO_ASSETS_DIR=./Podcast Automation Assets
